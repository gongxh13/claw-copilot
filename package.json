{
  "name": "claw-copilot",
  "version": "0.0.12",
  "description": "Run-aware observability dashboard plugin for OpenClaw",
  "repository": {
    "type": "git",
    "url": "https://github.com/gongxh13/claw-copilot"
  },
  "workspaces": [],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "dist/node_modules",
    "openclaw.plugin.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "cd dashboard && npm install && npm run build && cd .. && tsup --config tsup.config.ts && rm -rf dist/dashboard && cp -R dashboard/dist dist/dashboard && mkdir -p dist/node_modules && cp -R node_modules/better-sqlite3 node_modules/bindings node_modules/file-uri-to-path dist/node_modules/",
    "dev": "tsx watch plugin/src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run check --workspace dashboard && tsc --noEmit",
    "postinstall": "npm rebuild better-sqlite3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "openclaw": "^2026.3.13",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "sql.js": "^1.14.1"
  }
}
