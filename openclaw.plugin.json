{
  "id": "crew-copilot",
  "name": "Crew Copilot",
  "description": "Run-aware observability dashboard for OpenClaw sessions",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "basePath": {
        "type": "string",
        "default": "/crew-copilot"
      },
      "dashboardTitle": {
        "type": "string",
        "default": "ClawCopilot"
      },
      "imVerbosity": {
        "type": "string",
        "enum": ["silent", "normal", "verbose"],
        "default": "normal"
      }
    }
  },
  "uiHints": {
    "basePath": {
      "label": "Base path",
      "help": "HTTP mount path for the dashboard routes"
    },
    "dashboardTitle": {
      "label": "Dashboard title"
    }
  }
}
